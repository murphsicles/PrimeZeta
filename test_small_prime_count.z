// Count primes up to 30 using simple trial division
fn main() -> u64 {
    let mut count: u64 = 0
    
    // Manually check numbers 2 through 30
    // 2 is prime
    count = count + 1
    
    // 3 is prime
    count = count + 1
    
    // 4 is not prime (divisible by 2)
    // 5 is prime
    count = count + 1
    
    // 6 is not prime
    // 7 is prime
    count = count + 1
    
    // 8, 9, 10 not prime
    // 11 is prime
    count = count + 1
    
    // 12, 13 prime
    count = count + 1
    
    // 14, 15, 16 not prime
    // 17 prime
    count = count + 1
    
    // 18, 19 prime
    count = count + 1
    
    // 20, 21, 22, 23 prime
    count = count + 1
    
    // 24, 25, 26, 27, 28 not prime
    // 29 prime
    count = count + 1
    
    // 30 not prime
    
    return count  // Should be 10 primes up to 30
}