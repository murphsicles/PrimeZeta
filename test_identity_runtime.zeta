// Test program for identity-aware runtime
// This demonstrates how string operations are validated at runtime
// based on identity capabilities.

// Main function to test identity-aware string operations
fn main() -> i32 {
    // Initialize identity context (this would be done by runtime)
    // In a real program, this would be set up before any string operations
    
    // Test string operations with different capabilities
    let s1 = "Hello, World!";
    let s2 = "Zeta";
    
    // Read operations should work with Read capability
    let len = str_len(s1);
    println("Length of s1: ", len);
    
    // Concat operation requires Read capability
    let combined = str_concat(s1, s2);
    println("Concatenated: ", combined);
    
    // Write operations require Write capability
    let lower = str_to_lowercase(s1);
    println("Lowercase: ", lower);
    
    // More operations
    let trimmed = str_trim("  Hello  ");
    println("Trimmed: '", trimmed, "'");
    
    let contains = str_contains(s1, "World");
    println("Contains 'World': ", contains);
    
    let replaced = str_replace(s1, "World", "Zeta");
    println("Replaced: ", replaced);
    
    0
}

