// Test different array syntaxes in Zeta

fn test1() {
    // Test 1: Zeta syntax [N]T
    let arr1: [10]i64 = [0; 10];
    println("Test 1: Zeta syntax [N]T");
}

fn test2() {
    // Test 2: Rust syntax [T; N]  
    let arr2: [i64; 10] = [0; 10];
    println("Test 2: Rust syntax [T; N]");
}

fn test3() {
    // Test 3: Empty array
    let arr3: [i64] = [];
    println("Test 3: Empty array");
}

fn test4() {
    // Test 4: Array with values
    let arr4: [i64; 3] = [1, 2, 3];
    println("Test 4: Array with values");
}

fn main() {
    test1();
    test2();
    test3();
    test4();
}