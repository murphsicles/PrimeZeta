fn main() -> i64 {
    let arr: [bool; 3] = [true, false, true];
    
    // Test all three values
    let mut result: i64 = 0;
    
    if arr[0] {  // Should be true (1)
        result += 1;
    }
    
    if !arr[1] {  // Should be false, so !false = true
        result += 2;
    }
    
    if arr[2] {  // Should be true (1)
        result += 4;
    }
    
    // Also test direct comparison
    if arr[0] == true {
        result += 8;
    }
    
    if arr[1] == false {
        result += 16;
    }
    
    result  // Should be 1 + 2 + 4 + 8 + 16 = 31 if all correct
}