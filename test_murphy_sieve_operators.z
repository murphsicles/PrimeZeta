fn main() -> i64 {
    // Test Murphy's Sieve basic logic with comparison operators
    let limit = 100;
    let mut count = 0;
    let mut i = 2;
    
    while i < limit {
        let mut is_prime = 1; // true
        let mut j = 2;
        
        while j * j <= i {
            if i % j == 0 {
                is_prime = 0; // false
                break;
            }
            j = j + 1;
        }
        
        if is_prime == 1 {
            count = count + 1;
        }
        
        i = i + 1;
    }
    
    return count; // Should return 25 primes under 100
}