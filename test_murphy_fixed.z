// Test actual Murphy's Sieve logic (fixed bounds)
fn main() -> u64 {
    let limit = 10  // Small limit that fits in our array
    
    // Simple sieve algorithm
    let mut is_prime = [true, true, true, true, true, true, true, true, true, true]  // 10 elements (0-9)
    
    // Mark 0 and 1 as not prime
    is_prime[0] = false
    is_prime[1] = false
    
    // Sieve of Eratosthenes (only up to array bounds)
    let mut p = 2
    
    while p * p <= limit {
        if p < 10 && is_prime[p] {  // Check bounds
            let mut multiple = p * p
            while multiple <= limit {
                if multiple < 10 {  // Check bounds
                    is_prime[multiple] = false
                }
                multiple += p
            }
        }
        p += 1
    }
    
    // Count primes (only within array bounds)
    let mut count = 0
    let mut i = 0
    
    while i <= limit && i < 10 {
        if is_prime[i] {
            count += 1
        }
        i += 1
    }
    
    // For limit=10, primes are: 2, 3, 5, 7 = 4 primes
    count
}