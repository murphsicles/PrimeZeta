// Unrolled sieve - computes primes up to 30 without loops
fn main() -> u64 {
    let mut count = 0
    
    // Check 2
    count = count + 1
    
    // Check 3 (not divisible by 2)
    count = count + 1
    
    // Check 5 (not divisible by 2 or 3)
    // 5 % 2 != 0 and 5 % 3 != 0
    count = count + 1
    
    // Check 7 (not divisible by 2, 3, or 5)
    count = count + 1
    
    // Check 11 (not divisible by 2, 3, 5, or 7)
    count = count + 1
    
    // Check 13
    count = count + 1
    
    // Check 17
    count = count + 1
    
    // Check 19
    count = count + 1
    
    // Check 23
    count = count + 1
    
    // Check 29
    count = count + 1
    
    return count  // Should be 10 primes up to 30
}