// Test all operators needed for Murphy's Sieve
fn main() -> u64 {
    let mut result = 0
    
    // Test subtraction
    let a = 10
    let b = 3
    let c = a - b  // Should be 7
    result = result + c
    
    // Test division
    let d = 100
    let e = 2
    let f = d / e  // Should be 50
    result = result + f
    
    // Test modulo
    let g = 13
    let h = 5
    let i = g % h  // Should be 3
    result = result + i
    
    // Test bitwise AND
    let j = 0b1100
    let k = 0b1010
    let l = j & k  // Should be 0b1000 = 8
    result = result + l
    
    // Test bitwise OR
    let m = 0b1100
    let n = 0b1010
    let o = m | n  // Should be 0b1110 = 14
    result = result + o
    
    // Test left shift
    let p = 1
    let q = p << 3  // Should be 8
    result = result + q
    
    return result  // Should be 7 + 50 + 3 + 8 + 14 + 8 = 90
}