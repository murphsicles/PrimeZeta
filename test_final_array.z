// Final test for hybrid memory system
// This should work with our fixes

fn stack_array_test() -> i64 {
    // Stack array - should work with runtime fixes
    let arr: [i64; 5] = [1, 2, 3, 4, 5];
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    while i < 5 {
        sum += arr[i as usize];
        i += 1;
    }
    sum  // Should return 15
}

fn main() -> i64 {
    stack_array_test()
}