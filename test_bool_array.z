// Test boolean array operations
fn main() -> u64 {
    // Boolean array
    let mut flags = [true, false, true, false, true]
    
    // Access boolean values
    let mut count = 0
    
    if flags[0] {
        count += 1
    }
    
    if flags[1] {
        count += 1
    }
    
    if flags[2] {
        count += 1
    }
    
    if flags[3] {
        count += 1
    }
    
    if flags[4] {
        count += 1
    }
    
    // Should count 3 true values
    count
}