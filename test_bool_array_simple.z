// Simple bool array test
fn main() -> i64 {
    let arr: [bool; 3] = [true, false, true];
    
    // Test reading values
    let v1 = arr[0];
    let v2 = arr[1];
    let v3 = arr[2];
    
    // Convert bools to i64 for return
    let mut result: i64 = 0;
    if v1 { result += 1; }
    if !v2 { result += 2; }
    if v3 { result += 4; }
    
    result
}