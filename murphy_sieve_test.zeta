// Simple Murphy's Sieve test
// This tests if arrays work for the sieve algorithm

fn simple_sieve(limit: i64) -> i64 {
    // Create a boolean array
    let mut sieve: [limit]bool = [true; limit];
    
    // 0 and 1 are not prime
    sieve[0] = false;
    sieve[1] = false;
    
    // Sieve of Eratosthenes
    let mut i = 2;
    while i * i < limit {
        if sieve[i] {
            let mut j = i * i;
            while j < limit {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    // Count primes
    let mut count = 0;
    let mut k = 0;
    while k < limit {
        if sieve[k] {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}

fn main() -> i64 {
    // Test with small limit
    let result = simple_sieve(100);
    // Should return 25 (primes under 100)
    return result;
}