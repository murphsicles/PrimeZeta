// Simple prime sieve test using bool array
fn main() -> i64 {
    let n: i64 = 10;
    let mut is_prime: [bool; 10] = [true; 10];
    
    // Mark 0 and 1 as not prime
    is_prime[0] = false;
    is_prime[1] = false;
    
    // Simple sieve
    let mut count: i64 = 0;
    for i in 0..n {
        if is_prime[i as usize] {
            count += 1;
        }
    }
    
    count  // Should be 4 (primes: 2, 3, 5, 7)
}