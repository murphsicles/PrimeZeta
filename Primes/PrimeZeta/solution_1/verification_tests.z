// Verification Tests for Murphy's Sieve
// Tests the algorithm against known prime counts

fn murphy_sieve(limit: u64) -> u64 {
    // Same implementation as prime.z
    if limit < 2 {
        return 0
    }
    if limit == 2 {
        return 1
    }
    
    let array_size = (limit / 2) as u64
    let sqrt_limit = (limit as f64).sqrt() as u64
    
    var count: u64 = 1
    var p: u64 = 3
    
    while p <= limit {
        var is_prime = true
        var d: u64 = 3
        
        while d * d <= p {
            if p % d == 0 {
                is_prime = false
                break
            }
            d = d + 2
        }
        
        if is_prime {
            count = count + 1
        }
        
        p = p + 2
    }
    
    return count
}

// Test function
fn test_murphy_sieve() -> bool {
    // Test cases with known prime counts
    let test_cases = [
        (10u64, 4u64),      // π(10) = 4
        (100u64, 25u64),    // π(100) = 25
        (1000u64, 168u64),  // π(1000) = 168
        (10000u64, 1229u64), // π(10000) = 1229
        (100000u64, 9592u64), // π(100000) = 9592
        (1000000u64, 78498u64), // π(1000000) = 78498
    ]
    
    var all_pass = true
    var i: u64 = 0
    
    while i < 6u64 {
        let limit = test_cases[i as usize].0
        let expected = test_cases[i as usize].1
        let result = murphy_sieve(limit)
        
        if result != expected {
            all_pass = false
            // In full implementation, we'd print error
        }
        
        i = i + 1
    }
    
    return all_pass
}

// Main verification function
fn main() -> u64 {
    let tests_passed = test_murphy_sieve()
    
    if tests_passed {
        return 1u64  // All tests passed
    } else {
        return 0u64  // Some tests failed
    }
}