fn main() -> i64 {
    // Test 1: Simple comparison (should work)
    let simple = if (1 < 2) { 100 } else { 200 };
    
    // Test 2: Nested if with comparison
    let nested = if (1 < 2) {
        if (3 < 4) {
            123
        } else {
            456
        }
    } else {
        789
    };
    
    // Return both results combined
    simple + nested
}