// Test i64 array repeat pattern
fn main() -> i64 {
    // This should create [7, 7, 7]
    let arr: [i64; 3] = [7; 3];
    
    // Sum all elements (should be 21)
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    while i < 3 {
        sum += arr[i as usize];
        i += 1;
    }
    
    sum
}