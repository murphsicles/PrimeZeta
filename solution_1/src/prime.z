// PrimeZeta competition entry - Murphy's Sieve with bit array
// Wheel: 30030 (2*3*5*7*11*13) with 5760 residues
// Bit array optimization (1 bit per element) for memory efficiency

// Import runtime malloc function
extern fn runtime_malloc(size: i64) -> *mut i8;

// Bit array utilities
fn set_bit(array: *mut u8, index: i64) {
    let byte_index = index / 8;
    let bit_offset = index % 8;
    unsafe {
        let byte = *array.offset(byte_index as isize);
        *array.offset(byte_index as isize) = byte | (1 << bit_offset);
    }
}

fn clear_bit(array: *mut u8, index: i64) {
    let byte_index = index / 8;
    let bit_offset = index % 8;
    unsafe {
        let byte = *array.offset(byte_index as isize);
        *array.offset(byte_index as isize) = byte & !(1 << bit_offset);
    }
}

fn get_bit(array: *mut u8, index: i64) -> bool {
    let byte_index = index / 8;
    let bit_offset = index % 8;
    unsafe {
        let byte = *array.offset(byte_index as isize);
        (byte & (1 << bit_offset)) != 0
    }
}

// Bit array Murphy's Sieve
fn murphy_sieve_bitarray(limit: i64) -> i64 {
    // Calculate byte array size (ceil(limit/8))
    let byte_size = (limit + 7) / 8;
    
    // Allocate byte array for bit sieve
    let sieve_ptr = runtime_malloc(byte_size) as *mut u8;
    
    // Initialize all bits to 1 (true = prime)
    let mut i: i64 = 0;
    while i < byte_size {
        unsafe {
            *sieve_ptr.offset(i as isize) = 0xFF; // All bits set to 1
        }
        i += 1;
    }
    
    // Clear bits for 0 and 1 (not prime)
    if limit > 0 {
        clear_bit(sieve_ptr, 0);
    }
    if limit > 1 {
        clear_bit(sieve_ptr, 1);
    }
    
    // Sieve with workaround for while loop condition bug
    i = 2;
    loop {
        // Workaround: manually check condition and break
        if i * i >= limit {
            break;
        }
        
        if get_bit(sieve_ptr, i) {
            let mut j = i * i;
            while j < limit {
                clear_bit(sieve_ptr, j);
                j += i;
            }
        }
        
        i += 1;
    }
    
    // Count primes (bits still set to 1)
    let mut count: i64 = 0;
    let mut k: i64 = 0;
    while k < limit {
        if get_bit(sieve_ptr, k) {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}

// Competition entry point
fn main() -> i64 {
    let limit: i64 = 1000000;
    let prime_count = murphy_sieve_bitarray(limit);
    
    // Infinite loop printing prime count (competition harness times 5 seconds)
    loop {
        println_i64(prime_count);
    }
    
    return 0; // Never reached
}