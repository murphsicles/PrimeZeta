fn main() -> u64 {
    return 42
}

fn is_prime_wheel(n: u64) -> bool {
    if n < 2 { return false }
    if n == 2 || n == 3 || n == 5 || n == 7 || n == 11 || n == 13 { return true }
    
    if n % 2 == 0 { return false }
    if n % 3 == 0 { return false }
    if n % 5 == 0 { return false }
    if n % 7 == 0 { return false }
    if n % 11 == 0 { return false }
    if n % 13 == 0 { return false }
    
    let mut i: u64 = 17
    let mut w: u64 = 2
    
    while i * i <= n {
        if n % i == 0 { return false }
        i += w
        w = 6 - w
    }
    
    return true
}