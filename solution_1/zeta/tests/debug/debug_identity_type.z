// Debug identity type parsing

// Test 1: Simple string type
fn test1() -> i64 {
    let s: str = "hello";
    return 1;
}

// Test 2: Identity type annotation
fn test2() -> i64 {
    let s: string[identity:read] = "hello";
    return 2;
}

// Test 3: What does the parser think string[identity:read] is?
fn main() -> i64 {
    test1() + test2()
}