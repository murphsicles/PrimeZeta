fn gcd(a: u64, b: u64) -> u64 {
    let mut x = a
    let mut y = b
    while y != 0 {
        let temp = y
        y = x % y
        x = temp
    }
    return x
}

fn is_prime_wheel(n: u64) -> bool {
    if n < 2 { return false }
    if n == 2 || n == 3 || n == 5 || n == 7 || n == 11 || n == 13 { return true }
    if n % 2 == 0 || n % 3 == 0 || n % 5 == 0 || n % 7 == 0 || n % 11 == 0 || n % 13 == 0 {
        return false
    }
    return true
}

fn main() -> u64 {
    return 42
}