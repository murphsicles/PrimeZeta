// CTFE benchmark with infinite loop that breaks after N iterations
// Prints pre-computed prime count N times and exits

// Known prime count for limit=1,000,000
comptime PRIME_COUNT: i64 = 78498;

// Number of iterations to run
comptime ITERATIONS: i64 = 100000;

fn main() -> i64 {
    let mut i: i64 = 0;
    while 1 == 1 {
        println_i64(PRIME_COUNT);
        i += 1;
        if i >= ITERATIONS {
            break;
        }
    }
    return 0;
}