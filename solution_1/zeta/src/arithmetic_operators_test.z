// Comprehensive arithmetic operators test for Zeta runtime

fn test_arithmetic() -> i64 {
    let a = 15;
    let b = 4;
    
    // Arithmetic operations
    let sum = a + b;          // 19
    let diff = a - b;         // 11
    let prod = a * b;         // 60
    let quot = a / b;         // 3 (integer division)
    let rem = a % b;          // 3
    
    // Bitwise operations
    let shl = a << b;         // 15 << 4 = 240
    let shr = a >> 1;         // 15 >> 1 = 7
    let band = a & b;         // 15 & 4 = 4
    let bor = a | b;          // 15 | 4 = 15
    let bxor = a ^ b;         // 15 ^ 4 = 11
    
    // Complex expression
    let complex = (a + b) * (a - b) / b;  // (19 * 11) / 4 = 209 / 4 = 52
    
    // Verify all results
    if sum != 19 { return 1; }
    if diff != 11 { return 2; }
    if prod != 60 { return 3; }
    if quot != 3 { return 4; }
    if rem != 3 { return 5; }
    if shl != 240 { return 6; }
    if shr != 7 { return 7; }
    if band != 4 { return 8; }
    if bor != 15 { return 9; }
    if bxor != 11 { return 10; }
    if complex != 52 { return 11; }
    
    0  // Success
}

fn main() -> i64 {
    test_arithmetic()
}