fn main() -> i64 {
    let a = 15;
    let b = 4;
    
    // Test arithmetic operators
    let sum = a + b;      // 19
    let diff = a - b;     // 11
    let prod = a * b;     // 60
    let quot = a / b;     // 3
    let rem = a % b;      // 3
    
    // Complex expression
    let complex = (a + b) * (a - b) / b;  // 52
    
    complex
}