// Test for Murphy's Sieve - complex expression with arithmetic and bitwise ops
fn main() -> i64 {
    let a = 42;
    let b = 13;
    let c = 7;
    
    // Complex expression: let x = a + b * c
    let x = a + b * c;
    
    // Bit operations for sieve
    let bit_test = (a << 2) | (b >> 1) & c ^ (a % b);
    
    // Combined test
    if x != 133 {  // 42 + 13*7 = 42 + 91 = 133
        return 1;
    }
    
    // Just return bit_test to see it works
    bit_test
}