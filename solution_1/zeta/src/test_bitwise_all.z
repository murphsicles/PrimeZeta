fn main() -> i64 {
    let a = 15;
    let b = 4;
    
    // Test each bitwise operator
    let shl = a << b;     // 240
    let shr = a >> 1;     // 7
    let band = a & b;     // 4
    let bor = a | b;      // 15
    let bxor = a ^ b;     // 11
    
    // Return a combination to verify all work
    (shl - 240) + (shr - 7) + (band - 4) + (bor - 15) + (bxor - 11)
}