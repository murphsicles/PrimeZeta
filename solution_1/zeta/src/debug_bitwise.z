fn main() -> i64 {
    let a = 10;
    let b = 20;
    
    let shift1 = a << 2;  // Should be 40
    let shift2 = b >> 1;  // Should be 10
    let or_result = shift1 | shift2;  // Should be 42
    
    // Return error code based on which test fails
    if shift1 != 40 { return 100 + shift1; }
    if shift2 != 10 { return 200 + shift2; }
    if or_result != 42 { return 300 + or_result; }
    
    0  // Success
}