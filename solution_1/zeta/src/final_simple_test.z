fn main() -> i64 {
    // Test from original request: let x = a + b * c
    let a = 10;
    let b = 20;
    let c = 30;
    let x = a + b * c;  // 10 + 20*30 = 10 + 600 = 610
    
    // Test bit operations for sieve
    let y = (a << 2) | (b >> 1);  // (10 << 2) | (20 >> 1) = 40 | 10 = 42
    
    x + y  // 610 + 42 = 652
}