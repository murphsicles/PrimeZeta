fn main() -> i64 {
    let a = 15;
    let b = 4;
    
    // Arithmetic operators
    let sum = a + b;          // 19
    let diff = a - b;         // 11
    let prod = a * b;         // 60
    let quot = a / b;         // 3
    let rem = a % b;          // 3
    
    // Bitwise operators
    let shl = a << b;         // 240
    let shr = a >> 1;         // 7
    let band = a & b;         // 4
    let bor = a | b;          // 15
    let bxor = a ^ b;         // 11
    
    // Complex expression using all operators
    let result = ((a + b) * (a - b) / b) + ((a << b) >> 2) - (a & b) | (a ^ b);
    
    // Return 0 if all tests pass (simplified check)
    if sum != 19 { return 1; }
    if diff != 11 { return 2; }
    if prod != 60 { return 3; }
    if quot != 3 { return 4; }
    if rem != 3 { return 5; }
    if shl != 240 { return 6; }
    if shr != 7 { return 7; }
    if band != 4 { return 8; }
    if bor != 15 { return 9; }
    if bxor != 11 { return 10; }
    
    0  // Success!
}