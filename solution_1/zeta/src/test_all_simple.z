fn main() -> i64 {
    // Test all operators in sequence
    let r1 = 15 + 4;   // 19
    let r2 = 15 - 4;   // 11
    let r3 = 15 * 4;   // 60
    let r4 = 15 / 4;   // 3
    let r5 = 15 % 4;   // 3
    let r6 = 15 << 4;  // 240
    let r7 = 15 >> 1;  // 7
    let r8 = 15 & 4;   // 4
    let r9 = 15 | 4;   // 15
    let r10 = 15 ^ 4;  // 11
    
    // Return a hash of all results
    r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9 + r10
}