fn main() -> i64 {
    let a = 15;
    let b = 4;
    
    // Test addition
    let sum = a + b;
    if sum != 19 {
        return 100 + sum;
    }
    
    // Test subtraction
    let diff = a - b;
    if diff != 11 {
        return 200 + diff;
    }
    
    // Test multiplication
    let prod = a * b;
    if prod != 60 {
        return 300 + prod;
    }
    
    // Test division
    let quot = a / b;
    if quot != 3 {
        return 400 + quot;
    }
    
    // Test modulo
    let rem = a % b;
    if rem != 3 {
        return 500 + rem;
    }
    
    // Test left shift
    let shl = a << b;
    if shl != 240 {
        return 600 + shl;
    }
    
    // Test right shift
    let shr = a >> 1;
    if shr != 7 {
        return 700 + shr;
    }
    
    // Test bitwise AND
    let band = a & b;
    if band != 4 {
        return 800 + band;
    }
    
    // Test bitwise OR
    let bor = a | b;
    if bor != 15 {
        return 900 + bor;
    }
    
    // Test bitwise XOR
    let bxor = a ^ b;
    if bxor != 11 {
        return 1000 + bxor;
    }
    
    0  // All tests passed
}