// Test if fixed compiler can compile real algorithm
fn main() -> u64 {
    let limit = 1000000u64
    let mut count = 0u64
    
    // Simple trial division (test basic operators)
    let mut n = 2u64
    while n <= limit {
        let mut is_prime = true
        let mut d = 2u64
        
        while d * d <= n {
            if n % d == 0 {
                is_prime = false
                break
            }
            d += 1
        }
        
        if is_prime {
            count += 1
        }
        
        n += 1
    }
    
    return count  // Should return 78498
}