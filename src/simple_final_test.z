fn main() -> i64 {
    let a = 15;
    let b = 4;
    
    // Test each operator individually
    let sum = a + b;
    let diff = a - b;
    let prod = a * b;
    let quot = a / b;
    let rem = a % b;
    
    let shl = a << b;
    let shr = a >> 1;
    let band = a & b;
    let bor = a | b;
    let bxor = a ^ b;
    
    // Simple check - return 0 if all correct
    if sum == 19 && diff == 11 && prod == 60 && quot == 3 && rem == 3 &&
       shl == 240 && shr == 7 && band == 4 && bor == 15 && bxor == 11 {
        0
    } else {
        1
    }
}