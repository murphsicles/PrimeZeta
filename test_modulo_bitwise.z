// Test modulo and bitwise operators
fn main() -> u64 {
    let mut result = 0
    
    // Test modulo
    let a = 13
    let b = 5
    let c = a % b  // Should be 3
    result = result + c
    
    // Test bitwise AND
    let d = 0b1100  // 12
    let e = 0b1010  // 10
    let f = d & e   // Should be 0b1000 = 8
    result = result + f
    
    // Test bitwise OR  
    let g = 0b1100  // 12
    let h = 0b1010  // 10
    let i = g | h   // Should be 0b1110 = 14
    result = result + i
    
    // Test left shift
    let j = 1
    let k = j << 3  // Should be 8
    result = result + k
    
    return result  // Should be 3 + 8 + 14 + 8 = 33
}