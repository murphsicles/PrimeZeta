struct Point {
    x: i64,
    y: i64,
}

struct Rectangle {
    top_left: Point,
    bottom_right: Point,
}

fn area(rect: Rectangle) -> i64 {
    let width = rect.bottom_right.x - rect.top_left.x;
    let height = rect.bottom_right.y - rect.top_left.y;
    width * height
}

fn main() -> i64 {
    let p1 = Point { x: 0, y: 0 };
    let p2 = Point { x: 10, y: 20 };
    let rect = Rectangle { top_left: p1, bottom_right: p2 };
    area(rect)
}