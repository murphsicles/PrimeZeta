// Test bit operations in Zeta
fn main() -> u64 {
    let mut x: u64 = 0;
    
    // Set bit 0
    x = x | 1;
    
    // Set bit 1  
    x = x | 2;
    
    // Check if bit 0 is set
    let bit0_set: bool = (x & 1) != 0;
    
    // Check if bit 1 is set
    let bit1_set: bool = (x & 2) != 0;
    
    // Check if bit 2 is set (should be false)
    let bit2_set: bool = (x & 4) != 0;
    
    let mut result: u64 = 0;
    
    if (bit0_set) {
        result = result + 1;
    }
    
    if (bit1_set) {
        result = result + 2;
    }
    
    if (bit2_set) {
        result = result + 4;
    }
    
    // Should return 3 (1 + 2) since bits 0 and 1 are set
    return result;
}