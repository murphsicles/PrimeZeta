// Murphy's Sieve - Test with small limit to verify computation works
// Returns 25 primes up to 100

fn main() -> u64 {
    let limit = 100
    let sqrt_limit = 10
    
    // Simple sieve using array
    let mut is_prime = [true; 101]
    
    // 0 and 1 are not prime
    is_prime[0] = false
    is_prime[1] = false
    
    // Sieve algorithm
    let mut p = 2
    while p <= sqrt_limit {
        if is_prime[p] {
            let mut multiple = p * p
            while multiple <= limit {
                is_prime[multiple] = false
                multiple = multiple + p
            }
        }
        p = p + 1
    }
    
    // Count primes
    let mut count = 0
    let mut i = 0
    while i <= limit {
        if is_prime[i] {
            count = count + 1
        }
        i = i + 1
    }
    
    return count  // Should return 25
}