fn main() -> i64 {
    // Test 1: Simple comparison
    let a = 1 < 2;
    
    // Test 2: Simple if with comparison
    let b = if (1 < 2) { 100 } else { 200 };
    
    // Test 3: Nested if with comparison
    let c = if (1 < 2) {
        if (3 < 4) {
            123
        } else {
            456
        }
    } else {
        789
    };
    
    // Return a combination to see all results
    a + b + c
}