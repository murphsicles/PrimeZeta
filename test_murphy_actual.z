// Test actual Murphy's Sieve logic (simplified)
fn main() -> u64 {
    let limit = 100  // Small limit for testing
    
    // Simple sieve algorithm
    let mut is_prime = [true, true, true, true, true, true, true, true, true, true]  // 10 elements
    
    // Mark 0 and 1 as not prime
    is_prime[0] = false
    is_prime[1] = false
    
    // Sieve of Eratosthenes
    let mut p = 2
    
    while p * p <= limit {
        if is_prime[p] {
            let mut multiple = p * p
            while multiple <= limit {
                is_prime[multiple] = false
                multiple += p
            }
        }
        p += 1
    }
    
    // Count primes
    let mut count = 0
    let mut i = 0
    
    while i <= limit {
        if i < 10 && is_prime[i] {  // Only check within our array bounds
            count += 1
        }
        i += 1
    }
    
    // For limit=100, should return 25 primes
    // But our array only has 10 elements, so we'll get primes up to 9
    // Primes ≤ 9: 2, 3, 5, 7 = 4 primes
    count
}