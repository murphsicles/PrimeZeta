// Minimal test that should compile and run
fn main() -> i64 {
    // Simple algorithm: count primes up to 100
    let mut count = 0;
    let mut n = 2;
    
    while n <= 100 {
        let mut prime = 1;
        let mut d = 2;
        
        while d * d <= n {
            if n % d == 0 {
                prime = 0;
                break;
            }
            d = d + 1;
        }
        
        if prime == 1 {
            count = count + 1;
        }
        n = n + 1;
    }
    
    // Return count (should be 25)
    return count;
}