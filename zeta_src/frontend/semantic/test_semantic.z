use crate::frontend::ast::AstNode;
use crate::middle::resolver::resolver::Resolver;

fn test_basic_typecheck() -> bool {
    // Create a simple AST: 1 + 2
    let ast = AstNode::BinaryOp {
        op: "+".to_string(),
        left: Box::new(AstNode::Lit(1)),
        right: Box::new(AstNode::Lit(2)),
    };
    
    let mut resolver = Resolver::new();
    let asts = vec![ast];
    
    // This should pass type checking
    let result = resolver.typecheck(&asts);
    
    println!("Basic typecheck test: {}", if result { "PASS" } else { "FAIL" });
    result
}

fn test_type_mismatch() -> bool {
    // Create AST with type mismatch (this should fail)
    // Note: We need to create a more complex test since current infer_type
    // returns "i64" for most things
    println!("Type mismatch test: SKIPPED (needs more complex type system)");
    true
}

fn test_ctfe_eval() -> bool {
    // Test compile-time function evaluation
    let ast = AstNode::BinaryOp {
        op: "+".to_string(),
        left: Box::new(AstNode::Lit(10)),
        right: Box::new(AstNode::Lit(20)),
    };
    
    let resolver = Resolver::new();
    let result = resolver.ctfe_eval(&ast);
    
    match result {
        Some(30) => {
            println!("CTFE eval test: PASS (10 + 20 = 30)");
            true
        }
        Some(other) => {
            println!("CTFE eval test: FAIL (got {}, expected 30)", other);
            false
        }
        None => {
            println!("CTFE eval test: FAIL (got None)");
            false
        }
    }
}

fn test_let_statement_typecheck() -> bool {
    // Test let statement type checking
    // Create AST: let x = 42;
    let ast = AstNode::Let {
        name: "x".to_string(),
        ty: None,
        value: Box::new(AstNode::Lit(42)),
    };
    
    let mut resolver = Resolver::new();
    let asts = vec![ast];
    
    // This should pass type checking
    let result = resolver.typecheck(&asts);
    
    println!("Let statement typecheck test (untyped): {}", if result { "PASS" } else { "FAIL" });
    
    // Also test type inference
    let inferred_type = resolver.infer_type(&asts[0]);
    println!("  Inferred type: {}", inferred_type);
    
    result && inferred_type == "i64"
}

fn test_let_with_type_annotation() -> bool {
    // Test let statement with type annotation
    // Create AST: let x: i64 = 42;
    let ast = AstNode::Let {
        name: "x".to_string(),
        ty: Some("i64".to_string()),
        value: Box::new(AstNode::Lit(42)),
    };
    
    let mut resolver = Resolver::new();
    let asts = vec![ast];
    
    // This should pass type checking (type matches)
    let result = resolver.typecheck(&asts);
    
    println!("Let statement typecheck test (typed): {}", if result { "PASS" } else { "FAIL" });
    
    // Check that the type is correctly inferred as i64
    let inferred_type = resolver.infer_type(&asts[0]);
    println!("  Inferred type: {}", inferred_type);
    
    result && inferred_type == "i64"
}

fn test_variable_scope_resolution() -> bool {
    // Test basic variable declaration and usage
    // Create AST: let x = 42; x + 1;
    let ast1 = AstNode::Let {
        name: "x".to_string(),
        ty: None,
        value: Box::new(AstNode::Lit(42)),
    };
    
    let ast2 = AstNode::BinaryOp {
        op: "+".to_string(),
        left: Box::new(AstNode::Var("x".to_string())),
        right: Box::new(AstNode::Lit(1)),
    };
    
    let mut resolver = Resolver::new();
    let asts = vec![ast1, ast2];
    
    // This should pass type checking (x is defined)
    let result = resolver.typecheck(&asts);
    
    println!("Variable scope resolution test (basic): {}", if result { "PASS" } else { "FAIL" });
    result
}

fn test_variable_shadowing() -> bool {
    // Test variable shadowing in nested scopes
    // Create AST with shadowing: let x = 1; { let x = 2; x }
    // Note: We need block support for this test
    println!("Variable shadowing test: SKIPPED (needs block support)");
    true
}

fn test_undefined_variable() -> bool {
    // Test that using undefined variable fails
    // Create AST: x + 1 (where x is not defined)
    let ast = AstNode::BinaryOp {
        op: "+".to_string(),
        left: Box::new(AstNode::Var("undefined_var".to_string())),
        right: Box::new(AstNode::Lit(1)),
    };
    
    let mut resolver = Resolver::new();
    let asts = vec![ast];
    
    // This should FAIL type checking (undefined variable)
    let result = resolver.typecheck(&asts);
    
    // We expect this to fail, so invert the result
    let expected = !result;
    
    println!("Undefined variable test: {}", if expected { "PASS" } else { "FAIL" });
    println!("  (Expected failure, got: {})", if result { "PASS" } else { "FAIL" });
    expected
}

fn test_function_parameter_scope() -> bool {
    // Test that function parameters are in scope
    // Create AST: fn add(x: i64, y: i64) -> i64 { x + y }
    // Note: We need function definition support for this test
    println!("Function parameter scope test: SKIPPED (needs full function support)");
    true
}

fn test_duplicate_variable_declaration() -> bool {
    // Test that duplicate variable declaration in same scope fails
    // Create AST: let x = 1; let x = 2;
    let ast1 = AstNode::Let {
        name: "x".to_string(),
        ty: None,
        value: Box::new(AstNode::Lit(1)),
    };
    
    let ast2 = AstNode::Let {
        name: "x".to_string(),
        ty: None,
        value: Box::new(AstNode::Lit(2)),
    };
    
    let mut resolver = Resolver::new();
    let asts = vec![ast1, ast2];
    
    // This should FAIL type checking (duplicate declaration)
    let result = resolver.typecheck(&asts);
    
    // We expect this to fail, so invert the result
    let expected = !result;
    
    println!("Duplicate variable declaration test: {}", if expected { "PASS" } else { "FAIL" });
    println!("  (Expected failure, got: {})", if result { "PASS" } else { "FAIL" });
    expected
}

