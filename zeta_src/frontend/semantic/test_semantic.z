    println!("=== SEMANTIC ANALYSIS TESTS ===");
    println!("By: SEM, Semantic Child of Dark Factory");
    println!("");
    
    let mut all_passed = true;
    
    if !test_basic_typecheck() {
        all_passed = false;
    }
    
    if !test_type_mismatch() {
        all_passed = false;
    }
    
    if !test_ctfe_eval() {
        all_passed = false;
    }
    
    if !test_let_statement_typecheck() {
        all_passed = false;
    }
    
    if !test_let_with_type_annotation() {
        all_passed = false;
    }
    
    if !test_variable_scope_resolution() {
        all_passed = false;
    }
    
    if !test_variable_shadowing() {
        all_passed = false;
    }
    
    if !test_undefined_variable() {
        all_passed = false;
    }
    
    if !test_function_parameter_scope() {
        all_passed = false;
    }
    
    if !test_duplicate_variable_declaration() {
        all_passed = false;
    }
    
    println!("");
    if all_passed {
        println!("All tests PASSED!");
    } else {
        println!("Some tests FAILED!");
    }
}