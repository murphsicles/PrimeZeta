// Test arithmetic operators
fn main() -> u64 {
    let a = 10u64
    let b = 3u64
    
    // Test addition
    let sum = a + b  // 13
    
    // Test subtraction  
    let diff = a - b  // 7
    
    // Test multiplication
    let prod = a * b  // 30
    
    // Test division
    let quot = a / b  // 3
    
    // Test modulo
    let rem = a % b  // 1
    
    // Return combination to verify all work
    return sum + diff + prod + quot + rem  // 13 + 7 + 30 + 3 + 1 = 54
}