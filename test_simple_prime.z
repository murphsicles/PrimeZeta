fn main() -> i32 {
    let mut count: i32 = 0;
    
    for n in 2..10 {
        let mut is_prime: bool = true;
        for i in 2..n {
            if n % i == 0 {
                is_prime = false;
                break;
            }
        }
        if is_prime {
            count += 1;
        }
    }
    
    return count;
}