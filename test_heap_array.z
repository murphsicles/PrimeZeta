// Test heap array (dynamic size)
// This should still work

fn heap_array_test() -> i64 {
    // This creates a heap array (dynamic size)
    let size = 5;
    let arr: [i64; size] = [0; size];  // Array repeat syntax
    
    // Initialize array
    let mut i: i64 = 0;
    while i < size {
        arr[i as usize] = (i + 1) * 10;  // 10, 20, 30, 40, 50
        i += 1;
    }
    
    // Sum array
    let mut sum: i64 = 0;
    i = 0;
    while i < size {
        sum += arr[i as usize];
        i += 1;
    }
    sum  // Should return 150 (10+20+30+40+50)
}

fn main() -> i64 {
    heap_array_test()
}