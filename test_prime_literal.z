// Medium-scale prime sieve test with literal size
fn main() -> i64 {
    // Use literal instead of variable
    let mut is_prime = [true; 10000];
    
    // 0 and 1 are not prime
    is_prime[0] = false;
    is_prime[1] = false;
    
    // Sieve
    let mut i: i64 = 2;
    while i * i < 10000 {
        if is_prime[i as usize] {
            let mut j: i64 = i * i;
            while j < 10000 {
                is_prime[j as usize] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    // Count primes
    let mut count: i64 = 0;
    let mut k: i64 = 0;
    while k < 10000 {
        if is_prime[k as usize] {
            count += 1;
        }
        k += 1;
    }
    
    count  // Should return 1,229 for limit=10,000
}