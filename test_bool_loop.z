// Test bool array with loop
fn main() -> i64 {
    let arr: [bool; 3] = [true, false, true];
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    
    while i < 3 {
        if arr[i as usize] {
            sum += 1;
        }
        i += 1;
    }
    
    sum  // Should return 2 (two true values)
}