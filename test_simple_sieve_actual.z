// Simple sieve test with actual computations
fn main() -> u64 {
    let limit: u64 = 100
    let mut count: u64 = 0
    
    // Simple sieve for small limit
    let mut is_prime: [bool] = [true; 101]
    
    if limit >= 2 {
        count = count + 1  // Count 2
    }
    
    // Mark multiples of 2
    let mut i: u64 = 4
    while i <= limit {
        is_prime[i] = false
        i = i + 2
    }
    
    // Check odd numbers
    let mut p: u64 = 3
    while p * p <= limit {
        if is_prime[p] {
            let mut multiple: u64 = p * p
            while multiple <= limit {
                is_prime[multiple] = false
                multiple = multiple + p * 2
            }
        }
        p = p + 2
    }
    
    // Count primes
    p = 3
    while p <= limit {
        if is_prime[p] {
            count = count + 1
        }
        p = p + 2
    }
    
    return count
}