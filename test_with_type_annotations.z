fn main() -> i64 {
    let a: i64 = 15;
    let b: i64 = 4;
    
    // Test each operator
    let sum: i64 = a + b;      // 19
    let diff: i64 = a - b;     // 11
    let prod: i64 = a * b;     // 60
    let quot: i64 = a / b;     // 3
    let rem: i64 = a % b;      // 3
    
    let shl: i64 = a << b;     // 240
    let shr: i64 = a >> 1;     // 7
    let band: i64 = a & b;     // 4
    let bor: i64 = a | b;      // 15
    let bxor: i64 = a ^ b;     // 11
    
    // Complex expression
    let complex: i64 = (a + b) * (a - b) / b;  // 52
    
    // Return success code (0) if all tests pass
    // We'll just return the complex result to verify it works
    complex
}