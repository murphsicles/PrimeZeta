// Test different syntaxes for identity-constrained generics

// Syntax 1: Rust-like trait bound syntax (what tests use)
// fn process<T: Identity<read>>(x: T) -> i64

// Syntax 2: Zeta type constructor syntax (what parser expects)
// fn process(x: Identity<T: read>) -> i64

// Syntax 3: Direct identity type
// fn process(x: string[identity:read]) -> i64

// Let's test the simplest case first
fn main() -> i64 {
    let s: string[identity:read] = "hello";
    return 42;
}