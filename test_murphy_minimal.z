fn main() -> i64 {
    // Minimal Murphy's Sieve - count primes up to 10
    let limit = 10
    
    if limit < 2 {
        return 0
    }
    
    let mut count = 1  // prime 2
    
    let mut n = 3
    while n <= limit {
        let mut is_prime = 1
        
        let mut d = 3
        while d * d <= n {
            let remainder = n % d
            if remainder == 0 {
                is_prime = 0
            }
            d = d + 2
        }
        
        if is_prime == 1 {
            count = count + 1
        }
        
        n = n + 2
    }
    
    return count
}