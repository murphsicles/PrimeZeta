// Prime sieve using ONLY stack arrays (small limit)
fn main() -> i64 {
    let limit: i64 = 10;
    
    // Stack array - small size
    let mut is_prime: [bool; 10] = [false; 10];
    
    // Manually initialize (avoid array repeat)
    is_prime[2] = true;
    is_prime[3] = true;
    is_prime[5] = true;
    is_prime[7] = true;
    
    // Count primes
    let mut count: i64 = 0;
    let mut i: i64 = 0;
    while i < limit {
        if is_prime[i as usize] {
            count += 1;
        }
        i += 1;
    }
    
    count
}