// Test if type annotations work at all
fn test1() -> u64 {
    let x: u64 = 5
    return x
}

// Test array type annotation
fn test2() -> u64 {
    // This might fail
    let x: [u64] = [1, 2, 3]
    return x[0]
}

// Test with size
fn test3() -> u64 {
    // This might also fail
    let x: [u64; 3] = [1, 2, 3]
    return x[0]
}

fn main() -> u64 {
    return test1() + test2() + test3()
}