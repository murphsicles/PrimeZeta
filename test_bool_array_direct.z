fn main() -> i64 {
    let arr: [bool; 3] = [true, false, true];
    
    // Return each value as i64
    let v0: i64 = arr[0] as i64;  // Should be 1
    let v1: i64 = arr[1] as i64;  // Should be 0
    let v2: i64 = arr[2] as i64;  // Should be 1
    
    v0 * 100 + v1 * 10 + v2  // Should be 101 (1*100 + 0*10 + 1)
}