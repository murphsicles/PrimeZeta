// Test comparison operators with i64
fn main() -> i64 {
    let a = 5i64
    let b = 10i64
    
    if a < b {
        if b > a {
            if a <= a {
                if b >= b {
                    if a == a {
                        if a != b {
                            return 123  // All comparisons work!
                        }
                    }
                }
            }
        }
    }
    
    return 0
}