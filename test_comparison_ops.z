// Test comparison operators
fn main() -> u64 {
    let mut result = 0
    
    // Test <
    let mut i = 0
    while i < 10 {
        i = i + 1
    }
    result = result + i  // Should add 10
    
    // Test <=
    let mut j = 0
    while j <= 9 {
        j = j + 1
    }
    result = result + j  // Should add 10
    
    // Test ==
    let a = 5
    let b = 5
    if a == b {
        result = result + 1  // Should add 1
    }
    
    // Test !=
    let c = 5
    let d = 6
    if c != d {
        result = result + 1  // Should add 1
    }
    
    return result  // Should be 10 + 10 + 1 + 1 = 22
}