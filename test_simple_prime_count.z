fn main() -> i64 {
    // Simple prime count test
    let limit = 30;
    let mut count = 0;
    let mut i = 2;
    
    while i < limit {
        let mut is_prime = 1;
        let mut j = 2;
        
        while j < i {
            if i % j == 0 {
                is_prime = 0;
                break;
            }
            j = j + 1;
        }
        
        if is_prime == 1 {
            count = count + 1;
        }
        
        i = i + 1;
    }
    
    return count; // Should return 10 primes under 30
}