fn main() -> i64 {
    // Test all comparison operators
    let a = 5;
    let b = 10;
    let c = 5;
    
    // Test <
    if a < b {
        // Test >
        if b > a {
            // Test <=
            if a <= c {
                // Test >=
                if c >= a {
                    // Test ==
                    if a == c {
                        // Test !=
                        if a != b {
                            return 1; // All operators work
                        }
                    }
                }
            }
        }
    }
    
    return 0; // Something failed
}