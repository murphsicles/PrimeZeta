// Test comparison operators
fn main() -> u64 {
    let a = 5u64
    let b = 10u64
    
    if a < b {
        if b > a {
            if a <= a {
                if b >= b {
                    if a == a {
                        if a != b {
                            return 123  // All comparisons work!
                        }
                    }
                }
            }
        }
    }
    
    return 0
}