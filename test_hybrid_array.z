// Test hybrid memory system
// Stack array test
fn stack_array_test() -> i64 {
    let arr: [i64; 5] = [1, 2, 3, 4, 5];
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    while i < 5 {
        sum += arr[i as usize];
        i += 1;
    }
    sum
}

// Heap array test (dynamic size)
fn heap_array_test() -> i64 {
    let size = 10;
    let mut arr: [i64; size] = [0; size]; // This should use heap allocation
    let mut i: i64 = 0;
    while i < size {
        arr[i as usize] = i * 2;
        i += 1;
    }
    
    let mut sum: i64 = 0;
    i = 0;
    while i < size {
        sum += arr[i as usize];
        i += 1;
    }
    sum
}

fn main() -> i64 {
    let stack_result = stack_array_test();
    let heap_result = heap_array_test();
    stack_result + heap_result
}