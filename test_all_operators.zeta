fn main() -> i64 {
    let a = 15;
    let b = 3;
    
    // Test arithmetic operators
    print_i64(a + b);  // Should print 18
    print_i64(a - b);  // Should print 12
    print_i64(a * b);  // Should print 45
    print_i64(a / b);  // Should print 5
    print_i64(a % b);  // Should print 0
    
    println();
    
    // Test comparison operators
    print_i64(a == b);  // Should print 0 (false)
    print_i64(a != b);  // Should print 1 (true)
    print_i64(a < b);   // Should print 0 (false)
    print_i64(a > b);   // Should print 1 (true)
    print_i64(a <= b);  // Should print 0 (false)
    print_i64(a >= b);  // Should print 1 (true)
    
    println();
    
    // Test bitwise operators
    print_i64(a & b);   // Should print 3 (15 & 3 = 3)
    print_i64(a | b);   // Should print 15 (15 | 3 = 15)
    print_i64(a ^ b);   // Should print 12 (15 ^ 3 = 12)
    print_i64(a << 1);  // Should print 30 (15 << 1 = 30)
    print_i64(a >> 1);  // Should print 7 (15 >> 1 = 7)
    
    println();
    
    // Test logical operators (using i64 as boolean)
    let true_val = 1;
    let false_val = 0;
    
    print_i64(true_val && true_val);   // Should print 1
    print_i64(true_val && false_val);  // Should print 0
    print_i64(true_val || false_val);  // Should print 1
    print_i64(false_val || false_val); // Should print 0
    print_i64(!true_val);              // Should print 0
    print_i64(!false_val);             // Should print 1
    
    println();
    
    // Test complex expression: if a < b && c == d
    let c = 10;
    let d = 10;
    if a < b && c == d {
        print_i64(9999);  // Should NOT print
    } else {
        print_i64(42);    // Should print 42
    }
    
    println();
    
    0
}