// Simple test of Murphy's Sieve
fn main() -> u64 {
    let limit: usize = 1000;
    
    // Simple sieve implementation
    if limit < 2 {
        return 0;
    }
    
    let mut is_prime: [u8; 1001] = [1; 1001];
    is_prime[0] = 0;
    is_prime[1] = 0;
    
    let mut i = 2;
    while i * i <= limit {
        if is_prime[i] == 1 {
            let mut j = i * i;
            while j <= limit {
                is_prime[j] = 0;
                j += i;
            }
        }
        i += 1;
    }
    
    let mut count: u64 = 0;
    let mut k = 2;
    while k <= limit {
        if is_prime[k] == 1 {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}