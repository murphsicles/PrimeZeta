// Simple Murphy's Sieve workaround - NO && operator
fn main() -> u64 {
    let limit = 10
    
    // Boolean array for primes
    let mut is_prime = [true, true, true, true, true, true, true, true, true, true]
    
    // Mark 0 and 1 as not prime
    is_prime[0] = false
    is_prime[1] = false
    
    // Sieve - simple approach without complex conditions
    let mut p = 2
    
    // Loop 1: p from 2 to sqrt(limit)
    while p < 5 {  // sqrt(10) ≈ 3, but we'll go to 4
        // Check if p is prime
        if p < 10 {
            if is_prime[p] {
                // Mark multiples
                let mut multiple = p * 2
                while multiple < 10 {
                    is_prime[multiple] = false
                    multiple += p
                }
            }
        }
        p += 1
    }
    
    // Count primes
    let mut count = 0
    let mut i = 0
    
    while i < 10 {
        if is_prime[i] {
            count += 1
        }
        i += 1
    }
    
    // Should be 4 primes: 2, 3, 5, 7
    count
}