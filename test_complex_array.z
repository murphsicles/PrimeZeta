// Test complex array operations
fn main() -> u64 {
    // Create array with values
    let mut arr = [1, 2, 3, 4, 5]
    
    // Modify array elements
    arr[0] = 100
    arr[2] = 300
    arr[4] = 500
    
    // Calculate sum
    let mut sum = 0
    let mut i = 0
    
    while i < 5 {
        sum += arr[i]
        i += 1
    }
    
    // Should be: 100 + 2 + 300 + 4 + 500 = 906
    sum
}