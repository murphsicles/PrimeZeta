// Benchmark for const generics Murphy's Sieve
// This benchmark compares different implementations

// Import sieve implementations
// TODO: Update imports when const generics are implemented

// Simple sieve for comparison
comptime fn simple_sieve() -> [1000000]bool {
    let mut sieve = [true; 1000000];
    sieve[0] = false;
    sieve[1] = false;
    
    let mut i = 2;
    while i * i < 1000000 {
        if sieve[i] {
            let mut j = i * i;
            while j < 1000000 {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    return sieve;
}

// Optimized sieve with early exit
comptime fn optimized_sieve() -> [1000000]bool {
    let mut sieve = [true; 1000000];
    sieve[0] = false;
    sieve[1] = false;
    
    // Only check up to sqrt(LIMIT)
    let limit = 1000000;
    let sqrt_limit = 1000; // sqrt(1000000) ≈ 1000
    
    let mut i = 2;
    while i <= sqrt_limit {
        if sieve[i] {
            let mut j = i * i;
            while j < limit {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    return sieve;
}

// Benchmark runner
fn run_benchmark() -> i64 {
    let start_time = get_time();
    
    // Run simple sieve
    let sieve1 = simple_sieve();
    
    let mid_time = get_time();
    
    // Run optimized sieve  
    let sieve2 = optimized_sieve();
    
    let end_time = get_time();
    
    // Verify both give same result
    let mut count1 = 0;
    let mut count2 = 0;
    let mut i = 0;
    while i < 1000 {
        if sieve1[i] {
            count1 += 1;
        }
        if sieve2[i] {
            count2 += 1;
        }
        i += 1;
    }
    
    // Return timing difference (simplified)
    if count1 != count2 {
        return -1; // Error
    }
    
    return (end_time - start_time) / 1000; // Simplified timing
}

