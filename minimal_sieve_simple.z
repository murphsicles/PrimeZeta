// Minimal prime counter in Zeta
fn main() -> u64 {
    let mut count = 0
    let mut n = 2
    
    while n <= 100 {
        // Check if n is prime (simple trial division)
        let mut d = 2
        let mut is_prime = true
        
        while d < n {
            if n % d == 0 {
                is_prime = false
                break
            }
            d += 1
        }
        
        if is_prime {
            count += 1
        }
        n += 1
    }
    
    return count
}