// Minimal test of bit array infrastructure

// Test 1: Array initialization [N]T = [0; N]
fn test1() -> bool {
    const N: u64 = 10
    let arr: [N]u64 = [0; N]
    
    var i: u64 = 0
    while i < N {
        if arr[i] != 0 {
            return false
        }
        i += 1
    }
    
    return true
}

// Test 2: Bit operations
fn test2() -> bool {
    var word: u64 = 0
    
    // Set bit 3
    word = word | (1 << 3)
    if (word & (1 << 3)) == 0 {
        return false
    }
    
    // Clear bit 3
    word = word & ~(1 << 3)
    if (word & (1 << 3)) != 0 {
        return false
    }
    
    return true
}

// Test 3: Simple tzcnt
fn tzcnt_simple(x: u64) -> u64 {
    if x == 0 {
        return 64
    }
    
    var count: u64 = 0
    var y = x
    
    while (y & 1) == 0 {
        count += 1
        y >>= 1
    }
    
    return count
}

fn test3() -> bool {
    if tzcnt_simple(8) != 3 {  // 8 = 0b1000
        return false
    }
    
    if tzcnt_simple(1) != 0 {
        return false
    }
    
    if tzcnt_simple(0) != 64 {
        return false
    }
    
    return true
}

// Main test
fn main() -> u64 {
    if !test1() {
        return 1
    }
    
    if !test2() {
        return 2
    }
    
    if !test3() {
        return 3
    }
    
    return 0  // Success
}