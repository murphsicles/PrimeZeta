// Test identity type checking in type checker
fn main() {
    // Test identity type parsing with identity-aware string functions
    let x = read_only_string("hello");
    let y = read_write_string("world");
    let z = owned_string("immutable");
    
    // Just declare the variables to test type checking
    let _ = x;
    let _ = y;
    let _ = z;
}