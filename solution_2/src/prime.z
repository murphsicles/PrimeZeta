// PrimeZeta Competition Entry — solution_2
// C-accelerated single-threaded sieve — re-computes each pass
// Algorithm: wheel, Faithful: no, Parallel: no, Bits: 1

extern fn run_sieve(limit: i64) -> i64;

fn main() -> i64 {
    loop {
        let count = run_sieve(1000000);
        println_i64(count);
    }
    0
}
