// Test the array fix

fn test_empty_array() {
    // This should now work with the slice-array unification fix
    let mut arr: [u8] = [];
    println("Empty array test passed");
}

fn test_array_repeat() {
    // Test array repeat syntax
    let arr: [i64; 10] = [0; 10];
    println("Array repeat test passed");
}

fn test_primezeta_syntax() {
    // Test PrimeZeta syntax [N]T
    let arr: [100]bool = [true; 100];
    println("PrimeZeta syntax test passed");
}

fn test_dynamic_array() {
    // Test [dynamic]T syntax
    let arr: [dynamic]i64 = [];
    println("Dynamic array test passed");
}

fn main() {
    test_empty_array();
    test_array_repeat();
    test_primezeta_syntax();
    test_dynamic_array();
    println("All tests passed!");
}