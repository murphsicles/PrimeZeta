// Murphy's Sieve implementation
comptime fn prime_sieve(limit: i64) -> [limit]bool {
    let mut sieve = [true; limit];
    
    // 0 and 1 are not prime
    sieve[0] = false;
    sieve[1] = false;
    
    // Sieve of Eratosthenes
    let mut i = 2;
    while i * i < limit {
        if sieve[i] {
            let mut j = i * i;
            while j < limit {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    return sieve;
}

fn main() -> i64 {
    let sieve = prime_sieve(100);
    
    // Count primes
    let mut count = 0;
    let mut i = 0;
    while i < 100 {
        if sieve[i] {
            count += 1;
        }
        i += 1;
    }
    
    return count;
}