// Test with small limit to verify algorithm works
fn main() -> i64 {
    let limit = 30
    
    if limit < 2 {
        return 0
    }
    if limit < 3 {
        return 1
    }
    
    let mut count = 1  // prime 2
    
    let mut n = 3
    while n <= limit {
        let mut prime = 1
        
        // Trial division up to sqrt(n)
        let mut d = 3
        while d * d <= n {
            if n % d == 0 {
                prime = 0
                break
            }
            d = d + 2
        }
        
        if prime == 1 {
            count = count + 1
        }
        
        n = n + 2
    }
    
    return count
}