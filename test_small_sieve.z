// Test small sieve with array repeat syntax
fn main() -> u64 {
    let limit = 100  // Small limit for testing
    
    // Create boolean array for sieve
    let mut sieve = [true; limit]
    
    // Simple sieve of Eratosthenes
    sieve[0] = false
    sieve[1] = false
    
    let mut i = 2
    while i < limit {
        if sieve[i] {
            let mut j = i * i
            while j < limit {
                sieve[j] = false
                j += i
            }
        }
        i += 1
    }
    
    // Count primes
    let mut count = 0
    let mut n = 0
    while n < limit {
        if sieve[n] {
            count += 1
        }
        n += 1
    }
    
    return count
}