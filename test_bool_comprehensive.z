// Comprehensive bool test
fn main() -> bool {
    let arr: [bool; 5] = [true, false, true, false, true];
    // Test all positions
    let test1 = arr[0];  // should be true (1)
    let test2 = arr[1];  // should be false (0)
    let test3 = arr[2];  // should be true (1)
    let test4 = arr[3];  // should be false (0)
    let test5 = arr[4];  // should be true (1)
    
    // Return true if all tests pass
    test1 && !test2 && test3 && !test4 && test5
}