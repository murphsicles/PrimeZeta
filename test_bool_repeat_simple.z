// Test bool array repeat pattern
fn main() -> i64 {
    // This should create [false, false, false]
    let arr: [bool; 3] = [false; 3];
    
    // Check all elements are false (0)
    let mut result: i64 = 0;
    if !arr[0] { result += 1; }
    if !arr[1] { result += 2; }
    if !arr[2] { result += 4; }
    
    result  // Should be 1 + 2 + 4 = 7 if all false
}