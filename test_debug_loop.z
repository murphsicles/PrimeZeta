fn main() -> i32 {
    let mut count: i32 = 0;
    
    println!("Before loop");
    
    for n in 2..10 {
        println!("n = {}", n);
        let mut is_prime: bool = true;
        for i in 2..n {
            println!("  i = {}", i);
            if n % i == 0 {
                is_prime = false;
                break;
            }
        }
        if is_prime {
            count += 1;
            println!("  {} is prime", n);
        }
    }
    
    println!("After loop, count = {}", count);
    return count;
}