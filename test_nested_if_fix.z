// Test nested if with comparisons
fn main() -> i64 {
    // Simple comparison - should return 1
    let a = 1 < 2;
    
    // Simple if with comparison - should return 1
    let b = if (1 < 2) { 1 } else { 0 };
    
    // Nested if with comparisons - this is the bug case
    let c = if (1 < 2) {
        if (3 < 4) {
            123
        } else {
            0
        }
    } else {
        0
    };
    
    // Return combination to check all cases
    a + b + c
}