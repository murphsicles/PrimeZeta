// Murphy's Sieve workaround without && operator
fn main() -> u64 {
    let limit = 10
    
    // Boolean array
    let mut is_prime = [true, true, true, true, true, true, true, true, true, true]
    
    // Mark 0 and 1 as not prime
    is_prime[0] = false
    is_prime[1] = false
    
    // Sieve without && - use nested loops
    let mut p = 2
    
    // First loop: p * p <= limit
    loop {
        if p * p > limit {
            break
        }
        
        // Check bounds
        if p < 10 {
            if is_prime[p] {
                let mut multiple = p * p
                
                // Second loop: multiple <= limit
                loop {
                    if multiple > limit {
                        break
                    }
                    
                    // Check bounds
                    if multiple < 10 {
                        is_prime[multiple] = false
                    }
                    
                    multiple += p
                }
            }
        }
        
        p += 1
    }
    
    // Count primes without &&
    let mut count = 0
    let mut i = 0
    
    loop {
        if i > limit {
            break
        }
        
        if i >= 10 {
            break
        }
        
        if is_prime[i] {
            count += 1
        }
        
        i += 1
    }
    
    // Should be 4 primes: 2, 3, 5, 7
    count
}