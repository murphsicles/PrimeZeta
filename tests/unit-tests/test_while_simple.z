// Test while loop with array summation

fn test_while_sum() -> u64 {
    let arr: [3]u64 = [1, 2, 3]
    
    let mut i: u64 = 0
    let mut sum: u64 = 0
    
    // Simple while loop
    while i < 3 {
        // Try direct addition first
        sum = sum + 1
        i += 1
    }
    
    return sum
}

fn test_while_array_access() -> u64 {
    let arr: [3]u64 = [1, 2, 3]
    
    let mut i: u64 = 0
    let mut sum: u64 = 0
    
    // While loop with array access
    while i < 3 {
        let value = arr[i]
        sum = sum + value
        i += 1
    }
    
    return sum
}

fn main() -> u64 {
    let test1 = test_while_sum()
    let test2 = test_while_array_access()
    
    // Return combined: test1 * 100 + test2
    return test1 * 100 + test2
}