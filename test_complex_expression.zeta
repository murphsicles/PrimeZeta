fn main() -> i64 {
    let a = 5;
    let b = 10;
    let c = 5;
    let d = 5;
    
    // Test the complex expression: if a < b && c == d
    if a < b && c == d {
        print_i64(1);  // Should print 1
    } else {
        print_i64(0);
    }
    
    println();
    
    // Test more complex expressions
    let x = 15;
    let y = 3;
    
    // Test arithmetic and comparison
    if (x + y) > (x - y) {
        print_i64(2);  // Should print 2 (18 > 12)
    }
    
    if (x * y) == 45 {
        print_i64(3);  // Should print 3 (15 * 3 = 45)
    }
    
    if (x % y) == 0 {
        print_i64(4);  // Should print 4 (15 % 3 = 0)
    }
    
    println();
    
    // Test bitwise operators
    let bit_a = 0b1100; // 12
    let bit_b = 0b1010; // 10
    
    print_i64(bit_a & bit_b);  // Should print 8 (0b1000)
    print_i64(bit_a | bit_b);  // Should print 14 (0b1110)
    print_i64(bit_a ^ bit_b);  // Should print 6 (0b0110)
    print_i64(bit_a << 1);     // Should print 24 (0b11000)
    print_i64(bit_a >> 1);     // Should print 6 (0b0110)
    
    println();
    
    0
}