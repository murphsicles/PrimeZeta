fn main() -> i64 {
    let a = 5;
    let b = 10;
    
    // Test equality
    if a == b {
        print_i64(1000);
    } else {
        print_i64(1); // Should print 1
    }
    
    // Test inequality
    if a != b {
        print_i64(2); // Should print 2
    } else {
        print_i64(2000);
    }
    
    // Test less than
    if a < b {
        print_i64(3); // Should print 3
    } else {
        print_i64(3000);
    }
    
    // Test greater than
    if a > b {
        print_i64(4000);
    } else {
        print_i64(4); // Should print 4
    }
    
    // Test less than or equal
    if a <= b {
        print_i64(5); // Should print 5
    } else {
        print_i64(5000);
    }
    
    // Test greater than or equal
    if a >= b {
        print_i64(6000);
    } else {
        print_i64(6); // Should print 6
    }
    
    // Test with equal values
    let c = 5;
    if a == c {
        print_i64(7); // Should print 7
    } else {
        print_i64(7000);
    }
    
    if a <= c {
        print_i64(8); // Should print 8
    } else {
        print_i64(8000);
    }
    
    if a >= c {
        print_i64(9); // Should print 9
    } else {
        print_i64(9000);
    }
    
    println();
    
    0
}